# Build stage
FROM registry.access.redhat.com/ubi10/go-toolset:latest AS builder
USER root
ENV CGO_ENABLED=0
WORKDIR /workspace

COPY go.mod go.sum VERSION ./
COPY sdk/standard/go.mod ./sdk/standard/
RUN --mount=type=cache,target=/root/go/pkg/mod   \
    go mod download

COPY workflow/ ./workflow/
COPY common/ ./common/
COPY db/ ./db/
COPY ipam/ ./ipam/
COPY site-workflow/ ./site-workflow/
COPY workflow-schema/ ./workflow-schema/
COPY site-manager/ ./site-manager/
COPY cert-manager/ ./cert-manager/

RUN mkdir -p /var/secrets/temporal/certs

USER root
ENV CGO_ENABLED=0
WORKDIR /workspace/workflow
RUN --mount=type=cache,target=/root/go/pkg/mod   \
    --mount=type=cache,target=/root/.cache/go-build   \
    go build \
        -ldflags "-extldflags '-static' -w -s" \
        -o /app/workflow \
        ./cmd/workflow

# Runtime stage
FROM registry.access.redhat.com/ubi10/ubi-micro:latest

WORKDIR /app

COPY --from=builder /app/workflow /app/workflow
COPY --from=builder /var/secrets/temporal/certs /var/secrets/temporal/certs

USER 1001

ENTRYPOINT ["/app/workflow"]
