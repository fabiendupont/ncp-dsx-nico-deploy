# Build stage
FROM --platform=$BUILDPLATFORM golang:1.25.4 AS builder

ARG TARGETOS=linux
ARG TARGETARCH=amd64

ENV CGO_ENABLED=0
ENV GOOS=$TARGETOS
ENV GOARCH=$TARGETARCH

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

COPY go.mod go.sum VERSION ./
COPY sdk/standard/go.mod ./sdk/standard/
RUN go mod download

COPY site-agent/ ./site-agent/
COPY common/ ./common/
COPY site-manager/ ./site-manager/
COPY workflow-schema/ ./workflow-schema/
COPY site-workflow/ ./site-workflow/
COPY cert-manager/ ./cert-manager/

WORKDIR /workspace/site-agent
RUN go build \
        -ldflags "-extldflags '-static' -w -s" \
        -o /app/site-agent \
        ./cmd/site-agent

# Runtime stage
FROM registry.access.redhat.com/ubi9/ubi-micro:latest

WORKDIR /app

COPY --from=builder /app/site-agent /app/site-agent

USER 1001

EXPOSE 8080

ENTRYPOINT ["/app/site-agent"]
