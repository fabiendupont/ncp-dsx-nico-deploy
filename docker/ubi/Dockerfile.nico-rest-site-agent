# Build stage
FROM registry.access.redhat.com/ubi10/go-toolset:latest AS builder
USER root
ENV CGO_ENABLED=0
WORKDIR /workspace

COPY go.mod go.sum VERSION ./
COPY sdk/standard/go.mod ./sdk/standard/
RUN --mount=type=cache,target=/root/go/pkg/mod   \
    go mod download

COPY site-agent/ ./site-agent/
COPY common/ ./common/
COPY site-manager/ ./site-manager/
COPY workflow-schema/ ./workflow-schema/
COPY site-workflow/ ./site-workflow/
COPY cert-manager/ ./cert-manager/

USER root
ENV CGO_ENABLED=0
WORKDIR /workspace/site-agent
RUN --mount=type=cache,target=/root/go/pkg/mod   \
    --mount=type=cache,target=/root/.cache/go-build   \
    go build \
        -ldflags "-extldflags '-static' -w -s" \
        -o /app/site-agent \
        ./cmd/site-agent

# Runtime stage
FROM registry.access.redhat.com/ubi10/ubi-micro:latest

WORKDIR /app

COPY --from=builder /app/site-agent /app/site-agent

USER 1001

EXPOSE 8080

ENTRYPOINT ["/app/site-agent"]
